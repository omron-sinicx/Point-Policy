# Python environments — never copy the host venv into the image
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# Large data / model files — mount these as volumes at runtime
data/
*.pkl
*.npy
*.h5
*.hdf5

# Co-tracker checkpoint (downloaded inside container via pp-download-checkpoints)
co-tracker/checkpoints/

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store

# Logs and outputs
*.log
wandb/
runs/
outputs/
